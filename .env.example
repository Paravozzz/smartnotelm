# Copy to .env or export for local runs (Docker Compose uses its own env above).

# PostgreSQL (smartnotelm-api)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/smartnotelm
SPRING_DATASOURCE_USERNAME=smartnotelm
SPRING_DATASOURCE_PASSWORD=smartnotelm

# Ollama embeddings (optional; disable with embeddings.enabled=false)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI-compatible API (optional alternative)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
